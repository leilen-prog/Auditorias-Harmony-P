function renderHallazgos(){
  let items=ST.hallazgos;
  if(ST.hFilter==='abierto')items=items.filter(h=>h.estado==='abierto');
  else if(ST.hFilter==='proceso')items=items.filter(h=>h.estado==='proceso');
  else if(ST.hFilter==='cerrado')items=items.filter(h=>h.estado==='cerrado');
  else if(ST.hFilter==='recurrente')items=items.filter(h=>h.recurrente);

  const areaSel=document.getElementById('fh-area-sel');
  const areaVal=areaSel?areaSel.value:'';
  if(areaVal)items=items.filter(h=>h.areaId===areaVal);

  const searchEl=document.getElementById('fh-search');
  const q=(searchEl?searchEl.value:'').trim().toLowerCase();
  if(q)items=items.filter(h=>
    (h.texto||'').toLowerCase().includes(q)
    ||(h.area||'').toLowerCase().includes(q)
    ||(h.nota||'').toLowerCase().includes(q)
    ||(h.evaluador||'').toLowerCase().includes(q)
  );

  const body=document.getElementById('hallazgos-body');
  const empty=document.getElementById('hallazgos-empty');
  if(!items.length){body.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  body.innerHTML=items.map(h=>
    '<div class="hcard">'
    +'<div style="display:flex;align-items:flex-start;gap:8px">'
    +'<div style="flex:1;min-width:0">'
    +'<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:6px">'
    +'<span class="badge '+(h.nivel==='bad'?'b-bad':'b-warn')+'">'+(h.nivel==='bad'?'No cumple':'Por mejorar')+'</span>'
    +(h.recurrente?'<span class="badge b-recur">⚠ Recurrente '+h.veces+'x</span>':'')
    +'<span class="badge b-'+h.estado+'">'+(h.estado==='abierto'?'Abierto':h.estado==='proceso'?'En proceso':'Cerrado')+'</span>'
    +(h.ref==='Reporte rápido'?'<span class="badge b-rapido">📝 Rápido</span>':'')
    +'</div>'
    +'<div style="font-size:13px;font-weight:500;margin-bottom:3px">'+h.texto+'</div>'
    +'<div style="font-size:11px;color:var(--text2)">'+h.area+' · '+h.fecha+' · '+h.evaluador+(h.ref&&h.ref!=='Reporte rápido'?' · '+h.ref:'')+'</div>'
    +(h.nota?'<div style="font-size:11px;color:var(--text2);margin-top:5px;border-top:1px solid var(--border);padding-top:4px">Nota: '+h.nota+'</div>':'')
    +(h.foto&&(h.foto.antes||h.foto.despues)?'<div style="font-size:10px;color:var(--green2);margin-top:3px">'+(h.foto.antes?'📸 Foto antes · ':'')+(h.foto.despues?'📸 Foto después':'')+'</div>':'')
    +'<div style="display:flex;gap:6px;margin-top:9px;flex-wrap:wrap">'
    +'<button class="smbtn'+(h.estado==='proceso'?' ap':'')+'" onclick="setEstado(\''+h.id+'\',\'proceso\')">En proceso</button>'
    +(h.estado==='cerrado'?'<button class="smbtn" onclick="setEstado(\''+h.id+'\',\'abierto\')">Reabrir</button>':'')
    +'</div></div>'
    +'<button class="check-toggle'+(h.estado==='cerrado'?' done':'')+'" onclick="toggleCerrado(\''+h.id+'\')" title="'+(h.estado==='cerrado'?'Reabrir pendiente':'Marcar como cerrado')+'">'+(h.estado==='cerrado'?'✅':'⬜')+'</button>'
    +'</div></div>'
  ).join('');
}

function setEstado(id,estado){
  const h=ST.hallazgos.find(x=>x.id===id);if(!h)return;
  const anterior=h.estado;
  h.estado=estado;updateBadges();renderHallazgos(); // actualización optimista en pantalla

  fetch(WEB_API_URL, {
    method: "POST",
    headers: { "Content-Type": "text/plain;charset=utf-8" },
    body: JSON.stringify({action:'actualizarEstado', id:id, estado:estado})
  })
  .then(r=>r.json())
  .then(res=>{
    if(!res||!res.ok){
      h.estado=anterior;updateBadges();renderHallazgos();
      alert('No se pudo actualizar el estado en la nube: '+((res&&res.error)||'error desconocido')+'\nSe revirtió el cambio.');
    }
  })
  .catch(err=>{
    h.estado=anterior;updateBadges();renderHallazgos();
    alert('Error de conexión al actualizar el estado. Se revirtió el cambio.\n'+err.message);
  });
}

function renderHistorial(){
  let items=ST.historial;
  const areaSel=document.getElementById('hist-area-sel');
  const areaVal=areaSel?areaSel.value:'';
  if(areaVal)items=items.filter(ev=>ev.areaId===areaVal);

  const body=document.getElementById('hist-body');
  const empty=document.getElementById('hist-empty');
  if(!items.length){body.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  body.innerHTML=items.map(ev=>{
    const c=ev.pct>=85?'var(--green)':ev.pct>=70?'var(--amber)':'var(--red)';
    const parcial=ev.evaluados<ev.totalItems;
    return'<div class="hist-row">'
      +'<div style="flex:1"><div style="font-weight:500">'+ev.area+'</div>'
      +'<div style="font-size:10px;color:var(--text2)">'+ev.fecha+' · '+ev.evaluador+(ev.ref?' · '+ev.ref:'')+' · '+ev.evaluados+'/'+ev.totalItems+' ítems'+(parcial?' (parcial)':'')+'</div></div>'
      +'<div style="display:flex;gap:6px;align-items:center">'
      +(ev.bad?'<span class="badge b-bad">'+ev.bad+' ❌</span>':'')
      +(ev.warn?'<span class="badge b-warn">'+ev.warn+' ⚠️</span>':'')
      +'<span style="font-weight:600;color:'+c+'">'+ev.pct+'%</span></div></div>';
  }).join('');
}

function renderResumen(){
  const total=ST.historial.length;
  const abiertos=ST.hallazgos.filter(h=>h.estado==='abierto').length;
  const recurrentes=ST.hallazgos.filter(h=>h.recurrente).length;
  const avgPct=total?Math.round(ST.historial.reduce((a,e)=>a+e.pct,0)/total):0;
  const pc=avgPct>=85?'var(--green)':avgPct>=70?'var(--amber)':'var(--red)';
  document.getElementById('res-metrics').innerHTML=
    '<div class="mc"><div class="mn" style="color:'+pc+'">'+avgPct+'%</div><div class="ml">Promedio general</div></div>'
    +'<div class="mc"><div class="mn" style="color:var(--red)">'+abiertos+'</div><div class="ml">Hallazgos abiertos</div></div>'
    +'<div class="mc"><div class="mn" style="color:var(--purple)">'+recurrentes+'</div><div class="ml">Recurrentes</div></div>';
  const recs=ST.hallazgos.filter(h=>h.recurrente&&h.estado!=='cerrado');
  document.getElementById('res-recur').innerHTML=recs.length
    ?'<div class="sec-label" style="color:var(--purple)">Puntos recurrentes sin cerrar</div>'
    +recs.map(h=>'<div style="padding:8px 10px;border-radius:8px;background:var(--purplebg);border:1px solid #AFA9EC;margin-bottom:5px;font-size:12px"><span style="font-weight:500">'+h.texto+'</span><div style="font-size:10px;color:var(--purple);margin-top:2px">'+h.area+' · '+h.veces+'x reportado</div></div>').join('')
    :'';
  const byArea={};
  ST.historial.forEach(ev=>{
    if(!byArea[ev.areaId])byArea[ev.areaId]={label:ev.area,evals:0,sumPct:0,hallazgos:0};
    byArea[ev.areaId].evals++;byArea[ev.areaId].sumPct+=ev.pct;
  });
  ST.hallazgos.forEach(h=>{if(byArea[h.areaId]&&h.estado!=='cerrado')byArea[h.areaId].hallazgos++;});
  document.getElementById('res-areas').innerHTML=Object.values(byArea).map(a=>{
    const avg=Math.round(a.sumPct/a.evals);
    const c=avg>=85?'var(--green)':avg>=70?'var(--amber)':'var(--red)';
    return'<div class="hist-row"><div style="flex:1"><div style="font-weight:500">'+a.label+'</div><div style="font-size:10px;color:var(--text2)">'+a.evals+' evaluación(es)</div></div>'
      +'<div style="display:flex;gap:6px;align-items:center">'+(a.hallazgos?'<span class="badge b-warn">'+a.hallazgos+' abiertos</span>':'')+'<span style="font-weight:600;color:'+c+'">'+avg+'%</span></div></div>';
  }).join('')||'<div style="color:var(--text2);font-size:12px;padding:8px">Aún no hay evaluaciones.</div>';
}

function exportarResumen(){
  const avg=ST.historial.length?Math.round(ST.historial.reduce((a,e)=>a+e.pct,0)/ST.historial.length):0;
  const recs=ST.hallazgos.filter(h=>h.recurrente&&h.estado!=='cerrado').map(h=>'- '+h.texto+' ('+h.area+', '+h.veces+'x)').join('\n');
  const abiertos=ST.hallazgos.filter(h=>h.estado==='abierto').slice(0,15).map(h=>'- ['+( h.nivel==='bad'?'No cumple':'Por mejorar')+'] '+h.area+': '+h.texto).join('\n');
  const txt='RESUMEN DE AUDITORIAS OPERATIVAS Y DE SERVICIO — HARMONY PROJECTS\n\nEvaluaciones: '+ST.historial.length+' | Promedio: '+avg+'% | Hallazgos abiertos: '+ST.hallazgos.filter(h=>h.estado==='abierto').length+'\n\nPUNTOS RECURRENTES SIN CERRAR:\n'+(recs||'Ninguno')+'\n\nHALLAZGOS ABIERTOS PRIORITARIOS:\n'+(abiertos||'Ninguno');
  navigator.clipboard.writeText(txt).then(()=>alert('Resumen copiado al portapapeles')).catch(()=>{const w=window.open('','_blank');w.document.write('<pre>'+txt+'</pre>');});
}

document.getElementById('ep-fecha').value=new Date().toISOString().slice(0,10);
filterH('todos');
poblarSelectsArea();
cargarDatos();
</script>
