<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Harmony Projects — Auditorías Operativas y de Servicio</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--green:#1D9E75;--green2:#0F6E56;--green3:#085041;--gbg:#E1F5EE;--amber:#BA7517;--amberbg:#FAEEDA;--red:#A32D2D;--redbg:#FCEBEB;--purple:#534AB7;--purplebg:#EEEDFE;--blue:#1D6FA5;--bluebg:#E3F0F8;--gray:#5F5E5A;--graybg:#F1EFE8;--border:#e0e0e0;--bg:#f7f8f6;--white:#fff;--text:#1a1a1a;--text2:#5a5a5a;--radius:10px}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;background:var(--bg);color:var(--text);font-size:14px;min-height:100vh}
.app{max-width:700px;margin:0 auto;padding:0 0 3rem}
.top-bar{background:var(--white);border-bottom:1px solid var(--border);padding:12px 16px;display:flex;align-items:center;gap:10px;position:sticky;top:0;z-index:100}
.logo{width:60px;height:34px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.app-title{font-size:14px;font-weight:600;color:var(--text)}
.app-sub{font-size:11px;color:var(--text2)}
.top-right{margin-left:auto;display:flex;gap:6px}
.btn-s{padding:6px 12px;background:var(--white);color:var(--text);border:1px solid var(--border);border-radius:8px;font-size:11px;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:4px}
.btn-s:hover{background:var(--graybg)}
.main-tabs{display:flex;background:var(--white);border-bottom:1px solid var(--border);overflow-x:auto}
.mtab{padding:10px 14px;font-size:12px;font-weight:500;color:var(--text2);border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;font-family:inherit;transition:all .15s}
.mtab.active{color:var(--green2);border-bottom-color:var(--green2)}
.mtab:hover:not(.active){background:var(--graybg)}
.pane{padding:14px 16px}
.prop-label{font-size:10px;font-weight:600;color:var(--green2);letter-spacing:.06em;text-transform:uppercase;margin:12px 0 6px;display:flex;align-items:center;gap:5px}
.area-grid{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:4px}
.abtn{padding:7px 13px;border-radius:20px;font-size:12px;font-weight:500;cursor:pointer;border:1px solid var(--border);background:var(--white);color:var(--text2);transition:all .15s;font-family:inherit;display:flex;align-items:center;gap:5px}
.abtn:hover{background:var(--gbg);border-color:#5DCAA5;color:var(--green2)}
.abtn.active{background:var(--green2);color:#fff;border-color:var(--green2)}
.bc{border-radius:8px;padding:1px 5px;font-size:10px;display:none}
.abtn:not(.active) .bc{background:var(--redbg);color:var(--red)}
.abtn.active .bc{background:rgba(255,255,255,0.25);color:#fff}
.eval-panel{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:14px;margin-top:12px}
.eval-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.eval-title{font-size:14px;font-weight:600;color:var(--text)}
.eval-meta{display:flex;gap:8px;align-items:center;margin-bottom:10px;flex-wrap:wrap}
.mi{padding:7px 10px;font-size:12px;border:1px solid var(--border);border-radius:7px;background:var(--graybg);color:var(--text);font-family:inherit}
.mi:focus{outline:none;border-color:var(--green)}
.prog-wrap{margin-bottom:10px}
.prog-row{display:flex;justify-content:space-between;font-size:11px;color:var(--text2);margin-bottom:4px}
.prog-bg{background:var(--graybg);border-radius:4px;height:5px;overflow:hidden}
.prog-fill{height:100%;background:var(--green);border-radius:4px;transition:width .3s}
.cat-title{font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text2);margin:14px 0 7px;padding-bottom:5px;border-bottom:1px solid var(--border)}
.item-row{display:flex;align-items:flex-start;gap:8px;padding:10px 11px;border-radius:9px;border:1px solid var(--border);margin-bottom:6px;background:var(--white);transition:all .12s}
.item-row:hover{background:var(--graybg)}
.item-row.ok{border-color:#9FE1CB;background:var(--gbg)}
.item-row.warn{border-color:#FAC775;background:var(--amberbg)}
.item-row.bad{border-color:#F7C1C1;background:var(--redbg)}
.item-main{flex:1;min-width:0}
.item-text{font-size:13px;line-height:1.45;margin-bottom:2px;color:var(--text)}
.item-hint{font-size:11px;color:var(--text2);font-style:italic;margin-bottom:3px}
.item-w{font-size:10px;color:var(--text2);margin-bottom:3px}
.rb-group{display:flex;gap:4px;flex-shrink:0}
.rb{width:32px;height:32px;border-radius:8px;border:1px solid var(--border);background:var(--graybg);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;transition:all .12s}
.rb:hover{transform:scale(1.1)}
.rb.ok{background:var(--gbg);border-color:var(--green);box-shadow:0 0 0 2px var(--green)}
.rb.warn{background:var(--amberbg);border-color:var(--amber);box-shadow:0 0 0 2px var(--amber)}
.rb.bad{background:var(--redbg);border-color:var(--red);box-shadow:0 0 0 2px var(--red)}
.dtog{font-size:10px;color:var(--text2);background:none;border:none;cursor:pointer;padding:0;font-family:inherit;text-decoration:underline}
.dbox{display:none;margin-top:8px;padding-top:8px;border-top:1px solid var(--border)}
.dbox.open{display:block}
textarea.ni{width:100%;padding:6px 9px;font-size:12px;border:1px solid var(--border);border-radius:7px;background:var(--graybg);color:var(--text);font-family:inherit;resize:none;min-height:38px}
.photo-row{display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-top:7px}
.pbtn{padding:5px 10px;font-size:11px;border:1px dashed var(--border);border-radius:6px;background:transparent;color:var(--text2);cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:3px}
.pbtn:hover{border-color:var(--green);color:var(--green)}
.pthumb{width:36px;height:36px;border-radius:5px;object-fit:cover;border:1px solid var(--border)}
.ptag{font-size:9px;background:var(--graybg);color:var(--text2);padding:2px 5px;border-radius:4px}
.btn-p{padding:9px 18px;background:var(--green);color:#fff;border:none;border-radius:9px;font-size:13px;font-weight:500;cursor:pointer;display:inline-flex;align-items:center;gap:7px;font-family:inherit;transition:background .15s}
.btn-p:hover{background:var(--green2)}
.hcard{background:var(--white);border:1px solid var(--border);border-radius:10px;padding:12px;margin-bottom:8px}
.badge{font-size:10px;font-weight:600;padding:2px 8px;border-radius:9px;white-space:nowrap;display:inline-block}
.b-bad{background:var(--redbg);color:var(--red)}
.b-warn{background:var(--amberbg);color:var(--amber)}
.b-recur{background:var(--purplebg);color:var(--purple)}
.b-abierto{background:var(--redbg);color:var(--red)}
.b-proceso{background:var(--amberbg);color:var(--amber)}
.b-cerrado{background:var(--gbg);color:var(--green2)}
.smbtn{padding:5px 11px;font-size:11px;border:1px solid var(--border);border-radius:7px;background:transparent;cursor:pointer;font-family:inherit;color:var(--text2)}
.smbtn:hover{background:var(--graybg)}
.smbtn.ap{background:var(--amberbg);color:var(--amber);border-color:var(--amber)}
.smbtn.ac{background:var(--gbg);color:var(--green2);border-color:var(--green)}
.hist-row{display:flex;align-items:center;gap:8px;padding:9px 11px;border-radius:8px;border:1px solid var(--border);margin-bottom:6px;font-size:12px;background:var(--white)}
.hist-row:hover{background:var(--graybg)}
.mc{background:var(--white);border:1px solid var(--border);border-radius:9px;padding:12px;text-align:center}
.mn{font-size:22px;font-weight:600;margin-bottom:2px}
.ml{font-size:10px;color:var(--text2)}
.sec-label{font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--text2);margin:1rem 0 6px}
.filter-row{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.fbtn{padding:5px 12px;font-size:11px;border:1px solid var(--border);border-radius:8px;background:var(--white);cursor:pointer;font-family:inherit;color:var(--text2);transition:all .12s}
.fbtn.active{background:var(--green2);color:#fff;border-color:var(--green2)}
.fbtn.recur-btn{color:var(--purple);border-color:var(--purple)}
.fbtn.recur-btn.active{background:var(--purple);color:#fff}
.b-rapido{background:var(--bluebg);color:var(--blue)}
.check-toggle{width:34px;height:34px;border-radius:9px;border:1px solid var(--border);background:var(--white);font-size:16px;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .12s}
.check-toggle:hover{transform:scale(1.08)}
.check-toggle.done{background:var(--gbg);border-color:var(--green)}
.qr-nivel-btn.active{background:var(--amber);color:#fff;border-color:var(--amber)}
.qr-nivel-btn.active.bad{background:var(--red);border-color:var(--red)}
.empty-state{text-align:center;padding:2.5rem 1rem;color:var(--text2);font-size:13px}
.empty-icon{font-size:32px;display:block;margin-bottom:8px}
input[type=file]{display:none}
@media(max-width:480px){.eval-meta{flex-direction:column;align-items:stretch}.mi{width:100%!important}}
</style>
</head>
<body>
<div class="app">
<div class="top-bar">
  <div class="logo"><img src="data:image/png;base64," alt="Harmony Projects" style="width:34px;height:34px;object-fit:contain;border-radius:0;background:transparent"></div>
  <div>
    <div class="app-title">Harmony Projects</div>
    <div class="app-sub">Auditorías Operativas y de Servicio</div>
  </div>
  <div class="top-right">
    <button class="btn-s" onclick="abrirReporteRapido()" style="background:var(--green);color:#fff;border-color:var(--green)">📝 Reporte rápido</button>
    <button class="btn-s" onclick="goTab('hallazgos')">⚠ Hallazgos</button>
    <button class="btn-s" onclick="goTab('historial')">↺ Historial</button>
  </div>
</div>

<div class="main-tabs">
  <button class="mtab active" id="mt-eval" onclick="goTab('eval')">Evaluación</button>
  <button class="mtab" id="mt-hallazgos" onclick="goTab('hallazgos')">Hallazgos <span id="badge-open" style="display:none;background:#FCEBEB;color:#A32D2D;border-radius:8px;padding:1px 6px;font-size:10px;margin-left:3px"></span></button>
  <button class="mtab" id="mt-historial" onclick="goTab('historial')">Historial</button>
  <button class="mtab" id="mt-resumen" onclick="goTab('resumen')">Resumen</button>
</div>

<div id="pane-eval" class="pane">
  <div class="prop-label">🛏 Habitaciones</div>
  <div class="area-grid">
    <button class="abtn" onclick="openArea('rooms_harmony',this)">Harmony <span class="bc" id="bc-rooms_harmony"></span></button>
    <button class="abtn" onclick="openArea('rooms_sunset',this)">Sunset Shack <span class="bc" id="bc-rooms_sunset"></span></button>
    <button class="abtn" onclick="openArea('rooms_campo',this)">Campo <span class="bc" id="bc-rooms_campo"></span></button>
  </div>
  <div class="prop-label">🏠 Housekeeping</div>
  <div class="area-grid">
    <button class="abtn" onclick="openArea('hk_hLav',this)">Lavandería Harmony <span class="bc" id="bc-hk_hLav"></span></button>
    <button class="abtn" onclick="openArea('hk_hAreas',this)">Áreas Comunes Harmony <span class="bc" id="bc-hk_hAreas"></span></button>
    <button class="abtn" onclick="openArea('hk_sunset',this)">HK Sunset <span class="bc" id="bc-hk_sunset"></span></button>
    <button class="abtn" onclick="openArea('hk_campo',this)">HK Campo <span class="bc" id="bc-hk_campo"></span></button>
  </div>
  <div class="prop-label">🍽 Salones y Restaurantes</div>
  <div class="area-grid">
    <button class="abtn" onclick="openArea('salon_harmony',this)">Harmony + Bar <span class="bc" id="bc-salon_harmony"></span></button>
    <button class="abtn" onclick="openArea('cocina_harmony',this)">Cocina Harmony <span class="bc" id="bc-cocina_harmony"></span></button>
    <button class="abtn" onclick="openArea('salon_alchile',this)">Al Chile + Bar <span class="bc" id="bc-salon_alchile"></span></button>
    <button class="abtn" onclick="openArea('cocina_alchile',this)">Cocina Al Chile <span class="bc" id="bc-cocina_alchile"></span></button>
    <button class="abtn" onclick="openArea('salon_jb',this)">Juice Bar <span class="bc" id="bc-salon_jb"></span></button>
    <button class="abtn" onclick="openArea('salon_lv',this)">La Ventanita <span class="bc" id="bc-salon_lv"></span></button>
    <button class="abtn" onclick="openArea('casita',this)">Casita <span class="bc" id="bc-casita"></span></button>
  </div>
  <div class="prop-label">⚙ Operaciones</div>
  <div class="area-grid">
    <button class="abtn" onclick="openArea('fd_harmony',this)">Front Desk Harmony <span class="bc" id="bc-fd_harmony"></span></button>
    <button class="abtn" onclick="openArea('fd_sunset',this)">Front Desk Sunset <span class="bc" id="bc-fd_sunset"></span></button>
    <button class="abtn" onclick="openArea('hc',this)">Healing Centre <span class="bc" id="bc-hc"></span></button>
    <button class="abtn" onclick="openArea('tiendita',this)">Tiendita / Bookstore <span class="bc" id="bc-tiendita"></span></button>
    <button class="abtn" onclick="openArea('boh_harmony',this)">BOH / Jardín Harmony <span class="bc" id="bc-boh_harmony"></span></button>
    <button class="abtn" onclick="openArea('boh_sunset',this)">BOH / Jardín Sunset <span class="bc" id="bc-boh_sunset"></span></button>
    <button class="abtn" onclick="openArea('boh_campo',this)">BOH / Jardín Campo <span class="bc" id="bc-boh_campo"></span></button>
    <button class="abtn" onclick="openArea('mant_harmony',this)">Mantenimiento Harmony <span class="bc" id="bc-mant_harmony"></span></button>
    <button class="abtn" onclick="openArea('mant_sunset',this)">Mantenimiento Sunset <span class="bc" id="bc-mant_sunset"></span></button>
    <button class="abtn" onclick="openArea('mant_campo',this)">Mantenimiento Campo <span class="bc" id="bc-mant_campo"></span></button>
    <button class="abtn" onclick="openArea('reservaciones',this)">Reservaciones <span class="bc" id="bc-reservaciones"></span></button>
    <button class="abtn" onclick="openArea('surf_rack',this)">Surf Rack <span class="bc" id="bc-surf_rack"></span></button>
    <button class="abtn" onclick="openArea('recording_studio',this)">Recording Studio <span class="bc" id="bc-recording_studio"></span></button>
  </div>

  <div id="eval-panel" style="display:none;margin-top:12px">
    <div class="eval-panel">
      <div class="eval-header">
        <div class="eval-title" id="ep-title"></div>
        <button class="btn-s" onclick="closePanel()">✕</button>
      </div>
      <div class="eval-meta">
        <input class="mi" type="text" id="ep-eval" placeholder="Tu nombre *" style="width:140px" required>
        <input class="mi" type="date" id="ep-fecha" style="width:135px">
        <input class="mi" type="text" id="ep-ref" placeholder="Ref: hab, turno..." style="width:135px">
      </div>
      <div class="prog-wrap">
        <div class="prog-row"><span id="ep-ptxt">0 / 0 evaluados</span><span id="ep-ppct" style="color:var(--green2);font-weight:600">0%</span></div>
        <div class="prog-bg"><div class="prog-fill" id="ep-pbar" style="width:0%"></div></div>
      </div>
      <div id="ep-body"></div>
      <div style="display:flex;gap:8px;margin-top:14px;flex-wrap:wrap">
        <button class="btn-p" onclick="guardarEval()">💾 Guardar evaluación</button>
        <button class="btn-s" onclick="closePanel()">Cancelar</button>
      </div>
    </div>
  </div>
</div>

<div id="pane-hallazgos" class="pane" style="display:none">
  <div class="filter-row">
    <button class="fbtn active" id="fh-todos" onclick="filterH('todos')">Todos</button>
    <button class="fbtn" id="fh-abierto" onclick="filterH('abierto')">Abiertos</button>
    <button class="fbtn" id="fh-proceso" onclick="filterH('proceso')">En proceso</button>
    <button class="fbtn" id="fh-cerrado" onclick="filterH('cerrado')">Cerrados</button>
    <button class="fbtn recur-btn" id="fh-recurrente" onclick="filterH('recurrente')">⚠ Recurrentes</button>
    <button class="fbtn" id="fh-refresh" onclick="cargarDatos(true)" style="margin-left:auto">🔄 Actualizar</button>
  </div>
  <div class="filter-row">
    <select class="mi" id="fh-area-sel" onchange="renderHallazgos()" style="flex:1;min-width:180px">
      <option value="">🔎 Todas las áreas</option>
    </select>
    <input class="mi" type="text" id="fh-search" placeholder="Buscar por descripción, nota o área..." style="flex:2;min-width:200px" oninput="renderHallazgos()">
  </div>
  <div id="hallazgos-sync-note" style="font-size:11px;color:var(--text2);margin-bottom:10px"></div>
  <div id="hallazgos-body"></div>
  <div class="empty-state" id="hallazgos-empty" style="display:none">
    <span class="empty-icon" style="color:var(--green)">✓</span>Sin hallazgos en esta categoría.
  </div>
</div>

<div id="pane-historial" class="pane" style="display:none">
  <div class="filter-row">
    <select class="mi" id="hist-area-sel" onchange="renderHistorial()" style="flex:1;min-width:180px">
      <option value="">🔎 Todas las áreas</option>
    </select>
    <button class="fbtn" onclick="cargarDatos(true)" style="margin-left:auto">🔄 Actualizar</button>
  </div>
  <div class="sec-label">Evaluaciones registradas</div>
  <div id="hist-body"></div>
  <div class="empty-state" id="hist-empty" style="display:none">
    <span class="empty-icon">↺</span>Aún no hay evaluaciones guardadas.
  </div>
</div>

<div id="pane-resumen" class="pane" style="display:none">
  <div class="sec-label">Resumen consolidado</div>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:1rem" id="res-metrics"></div>
  <div id="res-recur" style="margin-bottom:1rem"></div>
  <div class="sec-label">Por área</div>
  <div id="res-areas"></div>
  <div style="margin-top:1rem;display:flex;gap:8px;flex-wrap:wrap">
    <button class="btn-p" onclick="exportarResumen()">📋 Copiar resumen para informe</button>
    <button class="btn-s" onclick="cargarDatos(true)">🔄 Actualizar</button>
  </div>
</div>
</div>

<div id="qr-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:flex-start;justify-content:center;padding:16px;overflow-y:auto">
  <div class="eval-panel" style="max-width:460px;width:100%;margin-top:40px">
    <div class="eval-header">
      <div class="eval-title">📝 Reporte rápido</div>
      <button class="btn-s" onclick="cerrarReporteRapido()">✕</button>
    </div>
    <div class="prop-label" style="margin-top:0">Área</div>
    <select class="mi" id="qr-area" style="width:100%;margin-bottom:12px">
      <option value="">Selecciona un área...</option>
    </select>

    <div class="prop-label">Nivel</div>
    <div style="display:flex;gap:6px;margin-bottom:12px">
      <button type="button" class="fbtn qr-nivel-btn" id="qr-nivel-warn" onclick="qrSetNivel('warn')" style="flex:1">⚠️ Por mejorar</button>
      <button type="button" class="fbtn qr-nivel-btn bad" id="qr-nivel-bad" onclick="qrSetNivel('bad')" style="flex:1">❌ No cumple</button>
    </div>

    <div class="prop-label">Descripción de la situación</div>
    <textarea class="ni" id="qr-texto" placeholder="Describe brevemente lo que encontraste..." style="width:100%;min-height:70px;margin-bottom:12px"></textarea>

    <div class="prop-label">Foto (opcional)</div>
    <div class="photo-row" style="margin-bottom:12px">
      <button class="pbtn" onclick="qrTomarFoto()">📷 Adjuntar foto</button>
      <img class="pthumb" id="qr-photo-thumb" style="display:none">
      <button class="pbtn" id="qr-photo-clear" style="display:none;border-color:var(--red);color:var(--red)" onclick="qrQuitarFoto()">✕ Quitar</button>
    </div>

    <div class="eval-meta" style="margin-top:2px">
      <input class="mi" type="text" id="qr-eval" placeholder="Tu nombre *" style="flex:1" required>
      <input class="mi" type="date" id="qr-fecha" style="flex:1">
    </div>

    <div style="display:flex;gap:8px;margin-top:14px;flex-wrap:wrap">
      <button class="btn-p" onclick="guardarReporteRapido()">💾 Guardar reporte</button>
      <button class="btn-s" onclick="cerrarReporteRapido()">Cancelar</button>
    </div>
  </div>
</div>

<input type="file" id="file-antes" accept="image/*" onchange="handlePhoto(this,'antes')">
<input type="file" id="file-despues" accept="image/*" onchange="handlePhoto(this,'despues')">
<input type="file" id="file-qr" accept="image/*" onchange="handleQrPhoto(this)">

<script>
// ==========================================
// CONFIGURACIÓN DE BACKEND: PEGA TU URL AQUÍ
// ==========================================
const WEB_API_URL = "https://script.google.com/macros/s/AKfycbxXsDxD8mow4ycbJorJobqjaEJt4LrpXIX7zZ5wiITXN-qjoD7FVDfbCPlyUGrTmvBy/exec";
const SL={
  rooms_harmony:'Habitaciones — Harmony Hotel',rooms_sunset:'Habitaciones — Sunset Shack',rooms_campo:'Habitaciones — Campo',
  hk_hLav:'Lavandería — Harmony',hk_hAreas:'Áreas Comunes — Harmony',hk_sunset:'Housekeeping — Sunset',hk_campo:'Housekeeping — Campo',
  salon_harmony:'Harmony Restaurant + Bar',cocina_harmony:'Cocina — Harmony',
