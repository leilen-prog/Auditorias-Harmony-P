function guardarReporteRapido(){
  const areaId=document.getElementById('qr-area').value;
  const texto=document.getElementById('qr-texto').value.trim();
  const evaluador=document.getElementById('qr-eval').value.trim();
  if(!areaId){alert('Selecciona un área.');return;}
  if(!evaluador){alert('Por favor ingresa tu nombre.');document.getElementById('qr-eval').focus();return;}
  if(!texto){alert('Describe la situación encontrada.');return;}
  if(!QR.nivel){alert('Indica si es "Por mejorar" o "No cumple".');return;}

  const payload={
    action:'reporteRapido',
    fecha:document.getElementById('qr-fecha').value||new Date().toISOString().slice(0,10),
    evaluador:evaluador,
    area:SL[areaId]||areaId,
    areaId:areaId,
    ref:'Reporte rápido',
    nivel:QR.nivel,
    texto:texto,
    nota:'',
    foto:{antes:QR.foto||''}
  };

  const btn=document.querySelector('#qr-overlay .btn-p');
  const original=btn.innerHTML;
  btn.innerHTML='⏳ Guardando...';btn.disabled=true;

  fetch(WEB_API_URL,{
    method:'POST',
    headers:{'Content-Type':'text/plain;charset=utf-8'},
    body:JSON.stringify(payload)
  })
  .then(r=>r.json())
  .then(res=>{
    if(!res||!res.ok)throw new Error((res&&res.error)||'Respuesta inválida del servidor');
    ST.hallazgos.unshift(res.hallazgo);
    updateBadges();
    cerrarReporteRapido();
    goTab('hallazgos');
  })
  .catch(err=>{
    alert('❌ No se pudo guardar el reporte rápido: '+err.message);
  })
  .finally(()=>{
    btn.innerHTML=original;btn.disabled=false;
  });
}

/** Alterna entre cerrado y abierto con un solo click (el "check" del pendiente) */
function toggleCerrado(id){
  const h=ST.hallazgos.find(x=>x.id===id);if(!h)return;
  setEstado(id, h.estado==='cerrado' ? 'abierto' : 'cerrado');
}

function guardarEval(){
  const id=ST.cur;if(!id)return;
  let totalPts=0,earned=0,ok=0,warn=0,bad=0,evaluados=0;
  const nuevos=[];
  
  itemIndex.forEach((it,idx)=>{
    const key=id+'__'+idx;
    const r=ST.ratings[key];if(!r)return;
    evaluados++;totalPts+=it.row.w;
    if(r==='ok'){earned+=it.row.w;ok++;}
    else if(r==='warn'){earned+=it.row.w*0.5;warn++;nuevos.push({texto:it.row.t,nivel:'warn',nota:ST.notes[key]||'',foto:ST.photos[key]||{}});}
    else if(r==='bad'){bad++;nuevos.push({texto:it.row.t,nivel:'bad',nota:ST.notes[key]||'',foto:ST.photos[key]||{}});}
  });
  
  const pct=totalPts?Math.round(earned/totalPts*100):0;
  const fecha=document.getElementById('ep-fecha').value||new Date().toISOString().slice(0,10);
  const evaluador=document.getElementById('ep-eval').value.trim();
  const ref=document.getElementById('ep-ref').value||'';

  if(!evaluador){
    alert('Por favor ingresa tu nombre antes de guardar la evaluación.');
    document.getElementById('ep-eval').focus();
    return;
  }

  // Construcción estructurada del payload JSON para el Apps Script
  const payloadBackend = {
    action: 'crear',
    fecha: fecha,
    evaluador: evaluador,
    area: SL[id] || id,
    areaId: id,
    ref: ref,
    pct: pct,
    ok: ok,
    warn: warn,
    bad: bad,
    totalItems: itemIndex.length,
    hallazgos: nuevos
  };

  // Indicador visual de red y bloqueo del botón para prevenir duplicados
  const btnGuardar = document.querySelector(".btn-p");
  const originalText = btnGuardar.innerHTML;
  btnGuardar.innerHTML = "⏳ Guardando en la nube...";
  btnGuardar.disabled = true;

  // Llamada HTTP POST al backend. Usamos Content-Type "text/plain" a propósito:
  // así el navegador no dispara un preflight OPTIONS (que Apps Script no maneja)
  // y podemos leer la respuesta normalmente (sin "no-cors").
  fetch(WEB_API_URL, {
    method: "POST",
    headers: { "Content-Type": "text/plain;charset=utf-8" },
    body: JSON.stringify(payloadBackend)
  })
  .then(r => r.json())
  .then(res => {
    if(!res || !res.ok) throw new Error((res && res.error) || 'Respuesta inválida del servidor');

    // El backend es la fuente de verdad: usamos los IDs, veces y recurrencia que calculó
    if(res.auditoria) ST.historial.unshift(res.auditoria);
    if(res.hallazgos && res.hallazgos.length) res.hallazgos.forEach(h=>ST.hallazgos.unshift(h));

    updateBadges();closePanel();
    alert('Auditoría guardada\n'+pct+'% · '+evaluados+'/'+itemIndex.length+' ítems · '+(warn+bad)+' hallazgo(s)\nDatos sincronizados en la hoja de cálculo.');
    goTab('hallazgos');
  })
  .catch(err => {
    console.error("Error al persistir auditoría:", err);
    alert('❌ Error de comunicación con el backend: '+err.message+'\nRevisa la URL del Web Script y que el despliegue esté activo.');
  })
  .finally(() => {
    btnGuardar.innerHTML = originalText;
    btnGuardar.disabled = false;
  });
}

function updateBadges(){
  const open=ST.hallazgos.filter(h=>h.estado==='abierto');
  const bo=document.getElementById('badge-open');
  if(open.length){bo.style.display='inline';bo.textContent=open.length;}else bo.style.display='none';
  Object.keys(SL).forEach(aid=>{
    const bc=document.getElementById('bc-'+aid);if(!bc)return;
    const n=ST.hallazgos.filter(h=>h.areaId===aid&&h.estado==='abierto').length;
    if(n){bc.style.display='inline';bc.textContent=n;}else bc.style.display='none';
  });
}

