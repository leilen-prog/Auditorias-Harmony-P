function poblarSelectsArea(){
  const opts=Object.entries(SL).sort((a,b)=>a[1].localeCompare(b[1]))
    .map(([id,label])=>'<option value="'+id+'">'+label+'</option>').join('');
  const sel1=document.getElementById('fh-area-sel');if(sel1)sel1.insertAdjacentHTML('beforeend',opts);
  const sel2=document.getElementById('hist-area-sel');if(sel2)sel2.insertAdjacentHTML('beforeend',opts);
  const sel3=document.getElementById('qr-area');if(sel3)sel3.insertAdjacentHTML('beforeend',opts);
}

function cargarDatos(manual){
  const note=document.getElementById('hallazgos-sync-note');
  if(note)note.textContent='⏳ Sincronizando con la nube...';
  fetch(WEB_API_URL+'?action=listado')
    .then(r=>r.json())
    .then(data=>{
      if(!data||!data.ok)throw new Error((data&&data.error)||'Respuesta inválida del servidor');
      ST.historial=data.historial||[];
      ST.hallazgos=data.hallazgos||[];
      updateBadges();
      renderHallazgos();renderHistorial();renderResumen();
      if(note)note.textContent='✓ Sincronizado — '+new Date().toLocaleTimeString('es-CR',{hour:'2-digit',minute:'2-digit'});
    })
    .catch(err=>{
      if(note)note.textContent='⚠ No se pudo sincronizar con la nube ('+err.message+'). Mostrando la última información disponible.';
      updateBadges();renderHallazgos();renderHistorial();renderResumen();
      if(manual)alert('No se pudo sincronizar con la nube:\n'+err.message);
    });
}

function goTab(t){
  ['eval','hallazgos','historial','resumen'].forEach(p=>{
    document.getElementById('pane-'+p).style.display='none';
    const m=document.getElementById('mt-'+p);if(m)m.classList.remove('active');
  });
  document.getElementById('pane-'+t).style.display='block';
  const m=document.getElementById('mt-'+t);if(m)m.classList.add('active');
  if(t==='hallazgos'||t==='historial'||t==='resumen'){
    renderHallazgos();renderHistorial();renderResumen();
    cargarDatos();
  }
}

function openArea(id,btn){
  ST.cur=id;ST.ratings={};ST.notes={};ST.photos={};
  document.querySelectorAll('.abtn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('ep-title').textContent=SL[id]||id;
  document.getElementById('ep-fecha').value=new Date().toISOString().slice(0,10);
  document.getElementById('ep-eval').value='';
  document.getElementById('ep-ref').value='';
  renderEvalBody(id);
  const panel=document.getElementById('eval-panel');
  panel.style.display='block';
  setTimeout(()=>panel.scrollIntoView({behavior:'smooth',block:'start'}),50);
}

function closePanel(){
  document.getElementById('eval-panel').style.display='none';
  document.querySelectorAll('.abtn').forEach(b=>b.classList.remove('active'));
  ST.cur='';ST.ratings={};ST.notes={};ST.photos={};
}

function renderEvalBody(id){
  const cats=ITEMS[id];
  if(!cats){document.getElementById('ep-body').innerHTML='<div style="color:var(--text2);font-size:12px;padding:8px">Sin criterios definidos.</div>';return;}
  itemIndex=[];
  let total=0,done=0,html='';
  Object.entries(cats).forEach(([cat,rows])=>{
    html+='<div class="cat-title">'+cat+'</div>';
    rows.forEach((row)=>{
      const idx=itemIndex.length;
      itemIndex.push({id,cat,row});
      const key=id+'__'+idx;
      const r=ST.ratings[key]||'';
      total++;if(r)done++;
      const ph=ST.photos[key]||{};
      html+='<div class="item-row'+(r?' '+r:'')+'" id="ir'+idx+'">'
        +'<div class="item-main">'
        +'<div class="item-text">'+row.t+'</div>'
        +(row.h?'<div class="item-hint">'+row.h+'</div>':'')
        +'<div class="item-w">Peso: '+row.w+' pts</div>'
        +'<button class="dtog" onclick="togDet('+idx+',this)">+ notas / foto</button>'
        +'<div class="dbox" id="db'+idx+'">'
        +'<textarea class="ni" placeholder="Observaciones..." onchange="ST.notes[\''+key+'\']=this.value">'+(ST.notes[key]||'')+'</textarea>'
        +'<div class="photo-row">'
        +'<button class="pbtn" onclick="tPhoto(\''+key+'\',\'antes\')">📷 Antes</button>'
        +'<button class="pbtn" onclick="tPhoto(\''+key+'\',\'despues\')">✅ Después</button>'
        +(ph.antes?'<img class="pthumb" src="'+ph.antes+'"><span class="ptag">Antes</span>':'')
        +(ph.despues?'<img class="pthumb" src="'+ph.despues+'"><span class="ptag">Después ✓</span>':'')
        +'</div></div></div>'
        +'<div class="rb-group">'
        +'<button class="rb'+(r==='ok'?' ok':'')+'" onclick="rate(\''+key+'\','+idx+',\'ok\',this)" title="Cumple">✅</button>'
        +'<button class="rb'+(r==='warn'?' warn':'')+'" onclick="rate(\''+key+'\','+idx+',\'warn\',this)" title="Por mejorar">⚠️</button>'
        +'<button class="rb'+(r==='bad'?' bad':'')+'" onclick="rate(\''+key+'\','+idx+',\'bad\',this)" title="No cumple">❌</button>'
        +'</div></div>';
    });
  });
  document.getElementById('ep-body').innerHTML=html;
  updProg(done,total);
}

function togDet(idx,btn){
  const el=document.getElementById('db'+idx);if(!el)return;
  const o=el.classList.toggle('open');
  btn.textContent=o?'- notas / foto':'+ notas / foto';
}

function rate(key,idx,val,btn){
  ST.ratings[key]=val;
  const row=document.getElementById('ir'+idx);
  if(row){
    row.querySelectorAll('.rb').forEach(b=>b.classList.remove('ok','warn','bad'));
    btn.classList.add(val);
    row.classList.remove('ok','warn','bad');row.classList.add(val);
    if(val==='warn'||val==='bad'){
      const db=document.getElementById('db'+idx);
      const dt=row.querySelector('.dtog');
      if(db&&!db.classList.contains('open')){db.classList.add('open');if(dt)dt.textContent='- notas / foto';}
    }
  }
  let done=0;
  itemIndex.forEach((_,i)=>{if(ST.ratings[ST.cur+'__'+i])done++;});
  updProg(done,itemIndex.length);
}

function updProg(d,t){
  const p=t?Math.round(d/t*100):0;
  document.getElementById('ep-ptxt').textContent=d+' / '+t+' evaluados';
  document.getElementById('ep-ppct').textContent=p+'%';
  document.getElementById('ep-pbar').style.width=p+'%';
}

function tPhoto(key,type){ST.curPhotoKey=key+'__'+type;document.getElementById('file-'+type).click();}

function handlePhoto(input,type){
  const f=input.files[0];if(!f)return;
  const reader=new FileReader();
  reader.onload=e=>{
    const key=ST.curPhotoKey.replace('__'+type,'');
    if(!ST.photos[key])ST.photos[key]={};
    ST.photos[key][type]=e.target.result;
    if(ST.cur)renderEvalBody(ST.cur);
  };
  reader.readAsDataURL(f);input.value='';
}

